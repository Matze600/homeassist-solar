uni-meter {
  output = "uni-meter.output-devices.sma-em"
  input  = "uni-meter.input-devices.home-assistant"

  input-devices {
    home-assistant {
      url          = "http://127.0.0.1:8123"
      access-token = "YOUR_HA_BEARER_TOKEN"

      power-phase-mode  = "mono-phase"
      energy-phase-mode = "mono-phase"

      # Hoymiles AC-Leistung — positiver Wert = Erzeugung
      # power-production-sensor: SMA sieht dies als Einspeisung (negatives Vorzeichen)
      power-production-sensor = "sensor.wechselrichter_ac_leistung"
    }
  }

  output-devices {
    sma-em {
      group         = "239.12.255.254"
      port          = 9522
      ttl           = 32
      send-interval = 1s
      serial-number = YOUR_SERIAL_NUMBER   # beliebige eindeutige 32-Bit-Zahl
      susy-id       = 270
    }
  }
}
