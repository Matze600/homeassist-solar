# Home Assistant - sensible Daten
# .storage: nur Lovelace-Dashboards versionieren, den Rest ignorieren
config/.storage/*
!config/.storage/lovelace*
config/.storage/lovelace*.corrupt*
config/.cloud/
config/secrets.yaml
config/known_devices.yaml
config/home-assistant_v2.db
config/home-assistant_v2.db-shm
config/home-assistant_v2.db-wal
config/home-assistant.log
config/home-assistant.log.*

# Home Assistant - generierte Dateien
config/.cache/
config/.ha_run.lock
config/deps/
config/tts/
config/.HA_VERSION
config/OZW_Log.txt

# HACS - wird automatisch installiert
config/custom_components/hacs/
config/custom_components/hoymiles_wifi/

# Python
**/__pycache__/
**/*.pyc

# Mosquitto - Laufzeitdaten
mosquitto/data/
mosquitto/log/

# Cloudflare Tunnel - Credentials (niemals committen!)
*.json
.cloudflared/
