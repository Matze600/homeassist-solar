# evcc - Electric Vehicle Charge Controller
# Dokumentation: https://docs.evcc.io
# UI: http://YOUR_HOST_IP:7070
#
# SETUP: Kopiere diese Datei nach evcc.yaml und trage deine Zugangsdaten ein.

network:
  schema: http
  host: 0.0.0.0
  port: 7070

sponsortoken: YOUR_EVCC_SPONSOR_TOKEN

log: info
interval: 30s

# ---------------------------------------------------------------------------
# Stromzähler — via Home Assistant REST API
# Umweg über HA weil WiFi kein Speedwire-Multicast weiterleitet
# HA liest SMA direkt (WebConnect) und stellt Daten per HTTP bereit
# ---------------------------------------------------------------------------
meters:
  # Grid-Meter: Netzleistung (positiv = Bezug, negativ = Einspeisung)
  # Berechnet in HA: metering_power_absorbed - metering_power_supplied
  - name: grid
    type: custom
    power:
      source: http
      uri: http://localhost:8123/api/states/sensor.netzleistung
      headers:
        Authorization: "Bearer YOUR_HA_BEARER_TOKEN"
      jq: '.state | tonumber? // 0'

  # PV-Meter: Gesamterzeugung inkl. Hoymiles
  - name: pv
    type: custom
    power:
      source: http
      uri: http://localhost:8123/api/states/sensor.pv_gesamtleistung
      headers:
        Authorization: "Bearer YOUR_HA_BEARER_TOKEN"
      jq: '.state | tonumber? // 0'

  # Batterie-Meter: Leistung (positiv = laden, negativ = entladen) + SOC
  - name: battery
    type: custom
    power:
      source: http
      uri: http://localhost:8123/api/states/sensor.batterieleistung
      headers:
        Authorization: "Bearer YOUR_HA_BEARER_TOKEN"
      jq: '.state | tonumber? // 0'
    soc:
      source: http
      uri: http://localhost:8123/api/states/sensor.sma_battery_soc_total
      headers:
        Authorization: "Bearer YOUR_HA_BEARER_TOKEN"
      jq: '.state | tonumber? // null'

# ---------------------------------------------------------------------------
# Ladegeräte (Easee — native Integration via Sponsor-Token)
# ---------------------------------------------------------------------------
chargers:
  - name: wallbox_1_master
    type: template
    template: easee
    user: YOUR_EASEE_EMAIL
    password: YOUR_EASEE_PASSWORD
    charger: YOUR_EASEE_CHARGER_ID_1
    timeout: 20s

  - name: wallbox_2
    type: template
    template: easee
    user: YOUR_EASEE_EMAIL
    password: YOUR_EASEE_PASSWORD
    charger: YOUR_EASEE_CHARGER_ID_2
    timeout: 20s

  - name: wallbox_3_aussen
    type: template
    template: easee
    user: YOUR_EASEE_EMAIL
    password: YOUR_EASEE_PASSWORD
    charger: YOUR_EASEE_CHARGER_ID_3
    timeout: 20s

  # ---------------------------------------------------------------------------
  # Heizstab (3x Shelly Plus 1PM) — reaktiviert 2026-06-14
  # Steuerung via evcc: pv-Modus normal, fast-Modus bei ≤0 ct/kWh (HA Automation)
  # ---------------------------------------------------------------------------
  - name: heizstab_l1
    type: template
    template: shelly
    host: 192.168.178.XX  # IP Shelly L1

  - name: heizstab_l2
    type: template
    template: shelly
    host: 192.168.178.XX  # IP Shelly L2

  - name: heizstab_l3
    type: template
    template: shelly
    host: 192.168.178.XX  # IP Shelly L3

# ---------------------------------------------------------------------------
# Stromtarif (Awattar = EPEX Spot Deutschland, Tagespreise)
# Rabot basiert ebenfalls auf EPEX Spot → günstige Stunden stimmen überein
# ---------------------------------------------------------------------------
tariffs:
  currency: EUR
  grid:
    type: awattar
    region: de

# ---------------------------------------------------------------------------
# Standort & Batterie-Strategie
# ---------------------------------------------------------------------------
site:
  title: "Solar Zuhause"
  meters:
    grid: grid
    pv: pv
    battery: battery
  residualPower: 0
  # prioritySoc und bufferSoc → in evcc UI unter Einstellungen konfigurieren

# ---------------------------------------------------------------------------
# Ladepunkte
# ---------------------------------------------------------------------------
loadpoints:
  - title: "Wallbox Master"
    charger: wallbox_1_master
    mode: pv
    enable:
      delay: 1m      # 1 Minute Überschuss nötig bevor Laden startet
    disable:
      delay: 5m      # 5 Minuten Pause nötig bevor Laden stoppt

  - title: "Wallbox 2"
    charger: wallbox_2
    mode: pv
    enable:
      delay: 1m
    disable:
      delay: 5m

  - title: "Wallbox Außen"
    charger: wallbox_3_aussen
    mode: pv
    enable:
      delay: 1m
    disable:
      delay: 5m

  # Heizstab reaktiviert 2026-06-14 — Steuerung via evcc + HA Automation
  - title: "Heizstab L1"
    charger: heizstab_l1
    mode: pv
    enable:
      delay: 1m
    disable:
      delay: 5m

  - title: "Heizstab L2"
    charger: heizstab_l2
    mode: pv
    enable:
      delay: 1m
    disable:
      delay: 5m

  - title: "Heizstab L3"
    charger: heizstab_l3
    mode: pv
    enable:
      delay: 1m
    disable:
      delay: 5m

# ---------------------------------------------------------------------------
# MQTT → Home Assistant Integration
# evcc publisht alle Werte nach Mosquitto; HA kann darauf subscriben
# ---------------------------------------------------------------------------
mqtt:
  broker: localhost:1883
  topic: evcc
  clientid: evcc
